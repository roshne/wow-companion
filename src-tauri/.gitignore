# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Mobile icon sets emitted by `tauri icon`. This is a desktop-only app, so the
# Android/iOS icons aren't tracked; re-running `tauri icon` won't dirty the tree.
/icons/android/
/icons/ios/
